{
  "name": "linkedin-share-resolver",
  "version": "1.0.0",
  "description": "Resolve LinkedIn Share post URLs to their public Activity permalinks via Playwright. Designed for Clay HTTP enrichment on Google Cloud Run.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run --config vitest.live.config.ts",
    "capture:cookies": "tsx scripts/captureCookies.ts",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "express": "^5.2.1",
    "playwright": "1.61.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
